# EchoVault API — server environment
PORT=4000

# --- AI provider (all optional; first one found wins) -----------------------
# Echo works with zero keys via the built-in offline "EchoBrain". Add ANY one
# of the free keys below to enable a real LLM for richer answers.

# Groq — free & very fast (recommended). Get a key: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter — free community models. Get a key: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Google Gemini — generous free tier. Get a key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
