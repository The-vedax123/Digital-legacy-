# EchoVault client — environment variables
# All are OPTIONAL. Without them, EchoVault runs in a fully-functional local demo mode.

# Supabase (enables cloud auth + storage). Leave blank for local demo mode.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# API base for the Express backend (Echo AI). Defaults to "/api" (proxied in dev).
VITE_API_URL=/api
