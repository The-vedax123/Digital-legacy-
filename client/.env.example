# EchoVault client — environment variables
# All are OPTIONAL. Without them, EchoVault runs in a fully-functional local demo mode.

# Supabase (enables cloud auth + storage). Leave blank for local demo mode.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# API base for the Express backend (Echo AI). Defaults to "/api" (proxied in dev).
VITE_API_URL=/api

# NOTE: The AI provider key (GROQ_API_KEY / OPENROUTER_API_KEY / GEMINI_API_KEY)
# is a SERVER-SIDE var used by the /api serverless functions — set it in Vercel
# project env vars (not here). Never expose an LLM key with a VITE_ prefix.
